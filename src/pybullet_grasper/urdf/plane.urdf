<?xml version="1.0" ?>
<robot name="plane">
  <link name="baseLink">
    <contact>
      <lateral_friction value="1"/>
      <rolling_friction value="0"/>
      <contact_cfm value="0.0"/>
      <contact_erp value="1.0"/>
    </contact>
    <inertial>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
       <mass value="0.2"/>
       <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://pybullet_grasper/objects/plane.obj" scale="1 1 1"/>
      </geometry>
       <material name="red">
        <color rgba="0.75 0.75 0.75 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
	 	<mesh filename="package://pybullet_grasper/objects/plane.obj" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>
  <link name="world">
    <inertial>
      <mass value="0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
  <joint name="plane_joint" type="prismatic">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="world"/>
    <child link="baseLink"/>
     <axis xyz="0 0 -1"/>
    <limit effort="1000" lower="-10" upper="10"/>
  </joint>
</robot>